# Email Configurations for SMTP
# Rename this file to '.env' in the backend/ directory to activate it.

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Your email address (e.g. yourname@gmail.com)
EMAIL_HOST_USER=yourname@gmail.com

# Your email password (for Gmail, this MUST be a 16-character "App Password", not your normal password)
EMAIL_HOST_PASSWORD=your_app_password_here

# Default From Email header
DEFAULT_FROM_EMAIL=yourname@gmail.com


# Twilio Configurations for SMS
# Fill these out to get real SMS OTP messages delivered to mobile phones.
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
